<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Produtos Recomendados - Rayhan Coelho</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Fraunces:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        :root {
            --orange: #e8821e;
            --orange-dark: #c2691a;
            --orange-darker: #a05518;
            --orange-bg: rgba(232, 130, 30, 0.08);
            --orange-border: rgba(232, 130, 30, 0.25);
            --dark: #1a1408;
            --text: rgba(255, 240, 220, 0.95);
            --text-muted: rgba(255, 220, 180, 0.7);
            --text-dim: rgba(255, 220, 180, 0.5);
            --success: #22c55e;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #1a1408 0%, #2a1f10 50%, #3a2f15 100%);
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        .container {
            max-width: 720px;
            margin: 0 auto;
            padding: 24px 20px 60px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 24px;
            padding: 8px 14px;
            background: var(--orange-bg);
            border-radius: 12px;
            border: 1px solid var(--orange-border);
        }

        /* HERO */
        .hero {
            text-align: center;
            margin-bottom: 36px;
        }

        .hero-badge {
            display: inline-block;
            background: var(--orange-bg);
            color: var(--orange);
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
            border: 1px solid var(--orange-border);
        }

        h1 {
            font-family: 'Fraunces', serif;
            font-size: 40px;
            font-weight: 900;
            line-height: 1.05;
            letter-spacing: -1.5px;
            margin-bottom: 14px;
            color: white;
        }

        h1 span {
            background: linear-gradient(135deg, #c2691a 0%, #e8821e 50%, #ffa500 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subtitle {
            font-size: 16px;
            color: var(--text-muted);
            max-width: 500px;
            margin: 0 auto;
            line-height: 1.5;
        }

        /* DISCLAIMER */
        .disclaimer {
            background: var(--orange-bg);
            border: 1.5px solid var(--orange-border);
            border-radius: 16px;
            padding: 16px 20px;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 13px;
            color: var(--text-muted);
        }

        .disclaimer-icon {
            font-size: 20px;
            flex-shrink: 0;
        }

        .disclaimer strong {
            color: var(--orange);
        }

        /* PRODUTOS */
        .products {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .product {
            background: rgba(255, 255, 255, 0.04);
            border: 1.5px solid rgba(255, 255, 255, 0.06);
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .product:active {
            transform: scale(0.98);
        }

        .product-image-wrapper {
            background: white;
            padding: 20px;
            position: relative;
            aspect-ratio: 16/10;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .product-image {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .product-tag {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(0, 0, 0, 0.85);
            color: white;
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            backdrop-filter: blur(10px);
        }

        .product-rating {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(0, 0, 0, 0.85);
            color: #fbbf24;
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
            backdrop-filter: blur(10px);
        }

        .product-content {
            padding: 24px;
        }

        .product-category {
            font-size: 11px;
            font-weight: 800;
            color: var(--orange);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
        }

        .product-title {
            font-family: 'Fraunces', serif;
            font-size: 24px;
            font-weight: 800;
            color: white;
            margin-bottom: 8px;
            line-height: 1.2;
            letter-spacing: -0.5px;
        }

        .product-description {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 16px;
        }

        .product-benefits {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 20px;
        }

        .product-benefit {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: var(--text);
        }

        .product-benefit-icon {
            color: var(--success);
            font-weight: 900;
            flex-shrink: 0;
        }

        .product-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #c2691a 0%, #e8821e 50%, #a05518 100%);
            color: white;
            text-decoration: none;
            border-radius: 14px;
            font-weight: 800;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            box-shadow: 0 12px 30px rgba(232, 130, 30, 0.35);
            transition: transform 0.2s;
        }

        .product-button:active {
            transform: scale(0.97);
        }

        /* SECTION DIVIDER */
        .section-divider {
            text-align: center;
            margin: 40px 0 24px;
            color: var(--orange);
            font-size: 20px;
            letter-spacing: 12px;
            opacity: 0.5;
        }

        /* CTA FINAL */
        .cta-final {
            background: linear-gradient(135deg, rgba(232, 130, 30, 0.15), rgba(160, 85, 24, 0.08));
            border: 1.5px solid var(--orange-border);
            border-radius: 24px;
            padding: 32px 24px;
            margin-top: 40px;
            text-align: center;
        }

        .cta-final-title {
            font-family: 'Fraunces', serif;
            font-size: 24px;
            font-weight: 800;
            color: white;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .cta-final-text {
            color: var(--text-muted);
            font-size: 15px;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .cta-final-button {
            display: inline-block;
            background: linear-gradient(135deg, #c2691a 0%, #e8821e 50%, #a05518 100%);
            color: white;
            padding: 14px 28px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 800;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            box-shadow: 0 12px 30px rgba(232, 130, 30, 0.4);
        }

        .footer {
            text-align: center;
            color: var(--text-dim);
            font-size: 12px;
            padding-top: 32px;
        }

        @media (max-width: 480px) {
            .container { padding: 16px 16px 40px; }
            h1 { font-size: 32px; }
            .product-image-wrapper { padding: 16px; aspect-ratio: 4/3; }
            .product-content { padding: 20px; }
            .product-title { font-size: 22px; }
        }
    </style>
</head>
<body>
    <div class="container">
